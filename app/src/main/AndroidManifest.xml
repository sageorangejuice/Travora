<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Travora"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".ui.homepage.StartActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.authentication.LoginActivity" />
        <activity android:name=".ui.authentication.RegistrationActivity" />
        <activity android:name=".ui.authentication.LocationActivity" />
        <activity android:name=".ui.authentication.ProfilingActivity" />
        <activity android:name=".ui.recommendations.RecommendationsActivity" />
        <activity android:name=".ui.reviews.ReviewsActivity" />
        <activity android:name=".ui.reviews.AddReviewActivity" />
        <activity android:name=".ui.profile.ProfileActivity" />

    </application>

</manifest>
