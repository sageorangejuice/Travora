<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/test_background_recommendations">

    <com.travora.app.ui.anim.BubbleBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/page_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Review Page"
            android:alpha="0.3"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_margin="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/main_vertical_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/activity_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reviews"
                android:textSize="40sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/place_image"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:contentDescription="Item Image"
                        android:clipToOutline="true"
                        tools:src="@drawable/sample_image" />

                    <TextView
                        android:id="@+id/place_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Sample Title"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        tools:text="Title Placeholder"/>

                    <TextView
                        android:id="@+id/place_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Sample Description"
                        android:textSize="16sp"
                        android:textColor="#DDFFFFFF"
                        tools:text="Description Placeholder"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#40FFFFFF"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="24dp"/>

                    <TextView
                        android:id="@+id/add_review_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="How was your experience?"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="12dp"/>

                    <RatingBar
                        android:id="@+id/place_ratingBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="0.5"
                        android:layout_gravity="start"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/review_input"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:hint="Write a review..."
                        android:gravity="top"
                        android:padding="12dp"
                        android:background="#30FFFFFF"
                        android:textColor="@color/white"
                        android:textColorHint="#A0FFFFFF"
                        android:layout_marginBottom="24dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="start"
                        android:layout_marginBottom="32dp">

                        <Button
                            android:id="@+id/local_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Local"
                            android:layout_marginEnd="12dp"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:textColor="@color/white"/>

                        <Button
                            android:id="@+id/Tourist_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tourist"
                            android:layout_marginEnd="12dp"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:textColor="@color/white"/>
                    </LinearLayout>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/submit_review_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Submit Review"
                        android:textStyle="bold"
                        android:textSize="25dp"
                        android:textColor="@color/white"
                        app:backgroundTint="#50FFFFFF"
                        app:strokeWidth="0dp"
                        app:strokeColor="#FFFFFF"
                        app:rippleColor="#70FFFFFF"/>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/nav_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            app:menu="@menu/nav_bar"
            app:itemIconTint="@null"
            app:itemTextColor="@color/white"
            android:background="#40000000"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
