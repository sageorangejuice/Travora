<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/test_background_login">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Login Page"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        tools:ignore="MissingConstraints" />
    <EditText
        android:id="@+id/email"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="  Email"
        android:textColorHint="@color/white"
        android:textStyle="italic"
        android:textSize="25dp"
        android:background="#50FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.55"/>
    <EditText
        android:id="@+id/password"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:hint="  Password"
        android:textColorHint="@color/white"
        android:textStyle="italic"
        android:textSize="25dp"
        android:inputType="textPassword"
        android:background="#50FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/email"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.01"/>
    <com.google.android.material.button.MaterialButton
        android:id="@+id/sign_in_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign In"
        android:textStyle="bold"
        android:textSize="40dp"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:backgroundTint="#50FFFFFF"
        app:strokeWidth="0dp"
        app:strokeColor="#FFFFFF"
        app:rippleColor="#70FFFFFF"
        app:layout_constraintVertical_bias="0.7"/>
    <Button
        android:id="@+id/forgot_password_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot Password"
        android:textStyle=""
        android:textSize="15dp"
        android:textColor="#90FFFFFF"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/sign_in_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/dhac"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dont have an account?"
        android:textStyle=""
        android:textSize="15dp"
        android:textColor="#90FFFFFF"
        android:background="@android:color/transparent"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        app:layout_constraintTop_toBottomOf="@id/forgot_password_button"
        app:layout_constraintEnd_toStartOf="@id/sign_in_button"
        app:layout_constraintHorizontal_chainStyle="packed"/>
    <Button
        android:id="@+id/sign_up_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" Sign up!"
        android:textStyle="bold"
        android:textSize="15dp"
        android:textColor="#90FFFFFF"
        android:background="@android:color/transparent"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        app:layout_constraintStart_toEndOf="@id/dhac"
        app:layout_constraintBaseline_toBaselineOf="@id/dhac"
        app:layout_constraintHorizontal_chainStyle="packed"/>


</androidx.constraintlayout.widget.ConstraintLayout>