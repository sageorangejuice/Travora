<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/test_background_login">

    <com.travora.app.ui.anim.BubbleBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tell me about yourself"
                    android:textSize="30dp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="32dp"/>

                <!-- Budget Section -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#25FFFFFF"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="What's your budget?"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <Button
                                android:id="@+id/budget_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Budget"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="#30FFFFFF"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:textColor="@color/white"/>
                            <Button
                                android:id="@+id/moderate_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Moderate"
                                android:backgroundTint="#30FFFFFF"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:textColor="@color/white"/>
                        </LinearLayout>
                        <Button
                            android:id="@+id/luxury_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Luxury"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="#30FFFFFF"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:textColor="@color/white"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Dietary Section -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#25FFFFFF"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Any dietary preferences?"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <Button
                                android:id="@+id/vegetarian_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vegetarian"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="#30FFFFFF"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:textColor="@color/white"/>
                            <Button
                                android:id="@+id/halal_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Halal"
                                android:backgroundTint="#30FFFFFF"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:textColor="@color/white"/>
                        </LinearLayout>
                        <Button
                            android:id="@+id/none_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="#30FFFFFF"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:textColor="@color/white"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Activities Section -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#25FFFFFF"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Type of activities you like?"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <Button
                                android:id="@+id/cultural_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cultural"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="#30FFFFFF"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:textColor="@color/white"/>
                            <Button
                                android:id="@+id/nature_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nature"
                                android:backgroundTint="#30FFFFFF"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:textColor="@color/white"/>
                        </LinearLayout>
                        <Button
                            android:id="@+id/shopping_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Shopping"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="#30FFFFFF"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:textColor="@color/white"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Dining Section -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#25FFFFFF"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Preferred dining?"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <Button
                                android:id="@+id/local_fave_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Local"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="#30FFFFFF"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:textColor="@color/white"/>
                            <Button
                                android:id="@+id/casual_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Casual"
                                android:backgroundTint="#30FFFFFF"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:textColor="@color/white"/>
                        </LinearLayout>
                        <Button
                            android:id="@+id/fine_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fine Dining"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="#30FFFFFF"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:textColor="@color/white"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/finish_profiling_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete Registration"
                    android:textStyle="bold"
                    android:textSize="25dp"
                    android:textColor="@color/white"
                    android:layout_marginBottom="24dp"
                    app:backgroundTint="#50FFFFFF"
                    app:strokeWidth="0dp"
                    app:strokeColor="#FFFFFF"
                    app:rippleColor="#70FFFFFF"/>
            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
