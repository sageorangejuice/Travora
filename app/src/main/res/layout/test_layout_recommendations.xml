<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/test_background_recommendations">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recommendations Page"
        android:alpha="0.3"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        tools:ignore="MissingConstraints" />

    <LinearLayout
        android:id="@+id/main_vertical_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal"
        tools:ignore="MissingConstraints">
        <TextView
            android:id="@+id/where_to"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Where to?"
            android:textSize="60sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginBottom="-20dp"/>




        <LinearLayout
            android:id="@+id/categories_button_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <!-- First button -->
            <Button
                android:id="@+id/dining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dining"
                android:textStyle=""
                android:textSize="15sp"
                android:textColor="@color/white"
                android:background="@android:color/transparent"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"/>

            <!-- Space between buttons -->
            <Space
                android:layout_width="16dp"
                android:layout_height="wrap_content" />

            <!-- Second button -->
            <Button
                android:id="@+id/activities"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activities"
                android:textStyle=""
                android:textSize="15dp"
                android:textColor="@color/white"
                android:background="@android:color/transparent"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"/>


        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_vertical">
            <EditText
            android:id="@+id/search_bar"
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:hint="  Destination"
            android:textColorHint="@color/white"
            android:textStyle="italic"
            android:textSize="25dp"
            android:inputType="textPassword"
            android:layout_marginEnd="-120dp"
            android:padding="0dp"
            android:background="#50FFFFFF"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/sign_in_button"
                android:layout_width="100sp"
                android:layout_height="40dp"
                android:text="Search"
                android:textStyle="bold"
                android:textSize="15dp"
                android:textColor="@color/white"
                android:layout_marginTop="-4dp"
                app:backgroundTint="#9060057f"
                app:strokeWidth="0dp"
                app:strokeColor="#FFFFFF"
                app:rippleColor="#70FFFFFF"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

    </LinearLayout>





</androidx.constraintlayout.widget.ConstraintLayout>